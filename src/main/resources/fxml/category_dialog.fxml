<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<DialogPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.controller.CategoryDialogController"
            prefWidth="400">

    <headerText>Category Details</headerText>

    <content>
        <VBox spacing="10" style="-fx-padding: 10 0 0 0;">

            <GridPane hgap="10" vgap="8">
                <columnConstraints>
                    <ColumnConstraints minWidth="110" halignment="RIGHT"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                </columnConstraints>

                <Label text="Name *"              GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="nameField"      GridPane.rowIndex="0" GridPane.columnIndex="1"
                           promptText="Category name" maxWidth="Infinity"/>

                <Label text="Slug"                GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <TextField fx:id="slugField"      GridPane.rowIndex="1" GridPane.columnIndex="1"
                           promptText="Auto-generated from name" maxWidth="Infinity"/>

                <Label text="Display Order"           GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <TextField fx:id="displayOrderField"  GridPane.rowIndex="2" GridPane.columnIndex="1"
                           promptText="0" prefWidth="80"/>

                <Label text="Active"              GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <CheckBox fx:id="activeCheck"     GridPane.rowIndex="3" GridPane.columnIndex="1"
                          selected="true"/>
            </GridPane>

            <Label fx:id="errorLabel" text="" wrapText="true"
                   style="-fx-text-fill: #c0392b; -fx-font-size: 11;"/>

        </VBox>
    </content>

    <buttonTypes>
        <ButtonType text="Save"   buttonData="OK_DONE"/>
        <ButtonType text="Cancel" buttonData="CANCEL_CLOSE"/>
    </buttonTypes>

</DialogPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<DialogPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.ecommerce.controller.UserDialogController"
            prefWidth="420">

    <headerText>User Details</headerText>

    <content>
        <VBox spacing="10" style="-fx-padding: 10 0 0 0;">
            <GridPane hgap="10" vgap="8">
                <columnConstraints>
                    <ColumnConstraints minWidth="110" halignment="RIGHT"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                </columnConstraints>

                <Label text="Full Name *"        GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="fullNameField" GridPane.rowIndex="0" GridPane.columnIndex="1"
                           maxWidth="Infinity"/>

                <Label text="Username *"         GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <TextField fx:id="usernameField" GridPane.rowIndex="1" GridPane.columnIndex="1"
                           maxWidth="Infinity"/>

                <Label text="Email *"            GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <TextField fx:id="emailField"    GridPane.rowIndex="2" GridPane.columnIndex="1"
                           maxWidth="Infinity"/>

                <Label text="Phone"              GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <TextField fx:id="phoneField"    GridPane.rowIndex="3" GridPane.columnIndex="1"
                           maxWidth="Infinity"/>

                <Label text="Role *"             GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                <ComboBox fx:id="roleCombo"      GridPane.rowIndex="4" GridPane.columnIndex="1"
                          maxWidth="Infinity"/>

                <Label text="Active"             GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                <CheckBox fx:id="activeCheck"    GridPane.rowIndex="5" GridPane.columnIndex="1"
                          selected="true"/>

                <Label text="Password *"          GridPane.rowIndex="6" GridPane.columnIndex="0"/>
                <PasswordField fx:id="passwordField" GridPane.rowIndex="6" GridPane.columnIndex="1"
                               maxWidth="Infinity" promptText="Leave blank to keep existing"/>
            </GridPane>

            <Label fx:id="errorLabel" text="" wrapText="true"
                   style="-fx-text-fill: #c0392b; -fx-font-size: 11;"/>
        </VBox>
    </content>

    <buttonTypes>
        <ButtonType text="Save"   buttonData="OK_DONE"/>
        <ButtonType text="Cancel" buttonData="CANCEL_CLOSE"/>
    </buttonTypes>
</DialogPane>

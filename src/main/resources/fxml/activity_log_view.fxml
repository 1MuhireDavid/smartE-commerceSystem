<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!--
  Activity Logs — NoSQL / JSONB demonstration view.

  Design rationale:
    Each event type (page_view, search, checkout_start, …) carries a completely
    different payload structure.  Storing these in a single relational table would
    require many nullable columns or a join-table per event type.
    PostgreSQL JSONB solves this: one event_data column stores any JSON shape and
    remains fully indexed and queryable via the ->> operator.

  This view shows:
    1. Stats bar       — aggregate counts per event type (GROUP BY event_type)
    2. Filter toolbar  — plain event-type filter OR JSONB ->> key/value search
    3. Log table       — last 200 events, double-click to see full JSON payload
    4. Log New Event   — insert form with per-event-type JSON templates,
                         demonstrating how different schemas coexist in one table
-->
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.ecommerce.controller.ActivityLogController"
      spacing="8" style="-fx-padding: 14;">

    <!-- ── Stats bar ── -->
    <Label fx:id="statsLabel" text="Loading stats…"
           style="-fx-text-fill: #2c3e50; -fx-font-size: 11; -fx-font-style: italic;"
           wrapText="true"/>

    <!-- ── Filter toolbar ── -->
    <HBox spacing="8" alignment="CENTER_LEFT">
        <Label text="Event type:"/>
        <ComboBox fx:id="eventTypeFilter" prefWidth="140" onAction="#handleSearch"/>

        <Separator orientation="VERTICAL"/>

        <!-- JSONB ->> key/value query -->
        <Label text="JSON key:" style="-fx-text-fill: #8e44ad;"/>
        <TextField fx:id="jsonKeyField"   promptText="e.g. product_id"
                   prefWidth="120" onAction="#handleSearch"
                   style="-fx-border-color: #8e44ad; -fx-border-radius: 3;"/>
        <Label text="=" style="-fx-font-weight: bold; -fx-text-fill: #8e44ad;"/>
        <TextField fx:id="jsonValueField" promptText="e.g. 1"
                   prefWidth="100" onAction="#handleSearch"
                   style="-fx-border-color: #8e44ad; -fx-border-radius: 3;"/>

        <Button text="Search" onAction="#handleSearch"
                style="-fx-background-color: #2980b9; -fx-text-fill: white;"/>
        <Button text="Clear"  onAction="#handleClear"/>
    </HBox>

    <Label text="  Purple fields: JSONB ->> query — searches inside the JSON payload. Example: key=query  value=macbook"
           style="-fx-text-fill: #8e44ad; -fx-font-size: 10;" wrapText="true"/>

    <!-- ── Log table (double-click row for full JSON) ── -->
    <TableView fx:id="logTable" VBox.vgrow="ALWAYS">
        <placeholder><Label text="No activity logs found"/></placeholder>
        <columns>
            <TableColumn fx:id="colId"        text="#"            prefWidth="50"/>
            <TableColumn fx:id="colUser"      text="User"         prefWidth="120"/>
            <TableColumn fx:id="colEventType" text="Event Type"   prefWidth="130"/>
            <TableColumn fx:id="colPayload"   text="JSON Payload (truncated — double-click for full)" prefWidth="420"/>
            <TableColumn fx:id="colDate"      text="Logged At"    prefWidth="150"/>
        </columns>
    </TableView>

    <!-- ── Log New Event (NoSQL insert demonstration) ── -->
    <TitledPane text="Log New Event  (demonstrates JSONB insert with PGobject)" expanded="true">
        <content>
            <VBox spacing="8" style="-fx-padding: 8;">

                <Label text="Each event type stores a different JSON schema — this is the NoSQL advantage: no ALTER TABLE needed for new payload fields."
                       style="-fx-text-fill: #7f8c8d; -fx-font-size: 11;" wrapText="true"/>

                <GridPane hgap="10" vgap="8">
                    <columnConstraints>
                        <ColumnConstraints minWidth="110" halignment="RIGHT"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                    </columnConstraints>

                    <Label text="Event Type *"    GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <ComboBox fx:id="newEventType" GridPane.rowIndex="0" GridPane.columnIndex="1"
                              maxWidth="Infinity" promptText="Select event type"/>

                    <Label text="User"            GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <ComboBox fx:id="userCombo"   GridPane.rowIndex="1" GridPane.columnIndex="1"
                              maxWidth="Infinity" promptText="system (leave blank for system events)"/>

                    <Label text="JSON Payload *"         GridPane.rowIndex="2" GridPane.columnIndex="0"
                           GridPane.valignment="TOP"/>
                    <TextArea fx:id="payloadArea"        GridPane.rowIndex="2" GridPane.columnIndex="1"
                              prefRowCount="6" wrapText="true" style="-fx-font-family: monospace;"/>
                </GridPane>

                <HBox spacing="8" alignment="CENTER_RIGHT">
                    <Button text="Insert Event" onAction="#handleLogEvent"
                            style="-fx-background-color: #8e44ad; -fx-text-fill: white;"/>
                </HBox>
            </VBox>
        </content>
    </TitledPane>

    <Label fx:id="feedbackLabel" text="" wrapText="true" style="-fx-font-size: 12;"/>

</VBox>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.ecommerce.controller.AllReviewsController"
      spacing="8" style="-fx-padding: 14;">

    <!-- ── Toolbar ── -->
    <HBox spacing="8" alignment="CENTER_LEFT">
        <Label text="Search product:"/>
        <TextField fx:id="searchField" promptText="Product name…" prefWidth="200"
                   onAction="#handleSearch"/>
        <Label text="Status:"/>
        <ComboBox fx:id="approvedFilter" onAction="#handleSearch" prefWidth="110"/>
        <Button text="Search" onAction="#handleSearch"
                style="-fx-background-color: #2980b9; -fx-text-fill: white;"/>
        <Button text="Clear" onAction="#handleClear"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="approveBtn" text="Approve" onAction="#handleApprove"
                style="-fx-background-color: #27ae60; -fx-text-fill: white;" disable="true"/>
        <Button fx:id="deleteBtn" text="Delete" onAction="#handleDelete"
                style="-fx-background-color: #e74c3c; -fx-text-fill: white;" disable="true"/>
    </HBox>

    <!-- ── Table ── -->
    <TableView fx:id="reviewTable" VBox.vgrow="ALWAYS">
        <placeholder><Label text="No reviews found"/></placeholder>
        <columns>
            <TableColumn fx:id="colProduct"  text="Product"   prefWidth="180"/>
            <TableColumn fx:id="colCustomer" text="Customer"  prefWidth="130"/>
            <TableColumn fx:id="colRating"   text="Rating"    prefWidth="90"/>
            <TableColumn fx:id="colApproved" text="Approved"  prefWidth="80"/>
            <TableColumn fx:id="colComment"  text="Comment"   prefWidth="280"/>
            <TableColumn fx:id="colDate"     text="Date"      prefWidth="130"/>
        </columns>
    </TableView>

    <Label fx:id="feedbackLabel" text="" wrapText="true" style="-fx-font-size: 12;"/>

</VBox>

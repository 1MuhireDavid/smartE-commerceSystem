<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.ecommerce.controller.InventoryController"
      spacing="8" style="-fx-padding: 14;">

    <!-- ── Toolbar ── -->
    <HBox spacing="8" alignment="CENTER_LEFT">
        <Label text="Search:"/>
        <TextField fx:id="searchField" promptText="Product name…" prefWidth="220"
                   onAction="#handleSearch"/>
        <CheckBox fx:id="lowStockOnly" text="Low stock only" onAction="#handleSearch"/>
        <Button text="Search" onAction="#handleSearch"
                style="-fx-background-color: #2980b9; -fx-text-fill: white;"/>
        <Button text="Clear"  onAction="#handleClear"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="updateBtn" text="Update Stock" onAction="#handleUpdate"
                style="-fx-background-color: #f39c12; -fx-text-fill: white;" disable="true"/>
        <Button fx:id="adjustBtn" text="Adjust (+/−)" onAction="#handleAdjust"
                style="-fx-background-color: #2980b9; -fx-text-fill: white;" disable="true"/>
    </HBox>

    <Label fx:id="lowStockBanner" text="" wrapText="true"
           style="-fx-text-fill: #c0392b; -fx-font-weight: bold;"/>

    <!-- ── Table ── -->
    <TableView fx:id="invTable" VBox.vgrow="ALWAYS">
        <placeholder><Label text="No inventory records"/></placeholder>
        <columns>
            <TableColumn fx:id="colProduct"   text="Product"      prefWidth="230"/>
            <TableColumn fx:id="colCategory"  text="Category"     prefWidth="120"/>
            <TableColumn fx:id="colStock"     text="In Stock"     prefWidth="80"/>
            <TableColumn fx:id="colReserved"  text="Reserved"     prefWidth="80"/>
            <TableColumn fx:id="colAvailable" text="Available"    prefWidth="80"/>
            <TableColumn fx:id="colReorder"   text="Reorder Lvl"  prefWidth="90"/>
            <TableColumn fx:id="colStatus"    text="Status"       prefWidth="90"/>
            <TableColumn fx:id="colUpdated"   text="Last Updated" prefWidth="130"/>
        </columns>
    </TableView>

    <Label fx:id="feedbackLabel" text="" wrapText="true"
           style="-fx-text-fill: #27ae60; -fx-font-size: 12;"/>
</VBox>

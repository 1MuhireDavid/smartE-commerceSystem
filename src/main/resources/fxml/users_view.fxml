<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.controller.UsersController"
      spacing="8" style="-fx-padding: 14;">

    <!-- ── Toolbar ── -->
    <HBox spacing="8" alignment="CENTER_LEFT">
        <Label text="Search:"/>
        <TextField fx:id="searchField" promptText="Name, email or username…" prefWidth="220"
                   onAction="#handleSearch"/>
        <Label text="Role:"/>
        <ComboBox fx:id="roleFilter" prefWidth="120" onAction="#handleSearch"
                  promptText="All roles"/>
        <Button text="Search" onAction="#handleSearch"
                style="-fx-background-color: #2980b9; -fx-text-fill: white;"/>
        <Button text="Clear"  onAction="#handleClear"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="addBtn"    text="Add User"  onAction="#handleAdd"
                style="-fx-background-color: #27ae60; -fx-text-fill: white;"/>
        <Button fx:id="editBtn"   text="Edit"      onAction="#handleEdit"
                style="-fx-background-color: #f39c12; -fx-text-fill: white;" disable="true"/>
        <Button fx:id="deleteBtn" text="Delete"    onAction="#handleDelete"
                style="-fx-background-color: #e74c3c; -fx-text-fill: white;" disable="true"/>
    </HBox>

    <!-- ── Table ── -->
    <TableView fx:id="userTable">
        <placeholder>
            <Label text="No users found"/>
        </placeholder>
        <columns>
            <TableColumn fx:id="colId"       text="ID"         prefWidth="60"/>
            <TableColumn fx:id="colName"     text="Full Name"  prefWidth="180"/>
            <TableColumn fx:id="colUsername" text="Username"   prefWidth="120"/>
            <TableColumn fx:id="colEmail"    text="Email"      prefWidth="210"/>
            <TableColumn fx:id="colRole"     text="Role"       prefWidth="90"/>
            <TableColumn fx:id="colActive"   text="Active"     prefWidth="70"/>
            <TableColumn fx:id="colCreated"  text="Joined"     prefWidth="130"/>
        </columns>
    </TableView>

    <Label fx:id="feedbackLabel" text="" wrapText="true"
           style="-fx-text-fill: #27ae60; -fx-font-size: 12;"/>
</VBox>

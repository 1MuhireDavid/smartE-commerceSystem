<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.controller.ReportsController"
      spacing="10" style="-fx-padding: 14;">

    <Label text="Business Reports"
           style="-fx-font-size: 15; -fx-font-weight: bold;"/>

    <!-- ── Summary cards ── -->
    <HBox spacing="12">
        <VBox style="-fx-background-color: #2980b9; -fx-padding: 12; -fx-background-radius: 6;"
              prefWidth="160" alignment="CENTER">
            <Label text="Total Revenue" style="-fx-text-fill: white; -fx-font-size: 11;"/>
            <Label fx:id="cardRevenue"  style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;" text="—"/>
        </VBox>
        <VBox style="-fx-background-color: #27ae60; -fx-padding: 12; -fx-background-radius: 6;"
              prefWidth="160" alignment="CENTER">
            <Label text="Total Orders" style="-fx-text-fill: white; -fx-font-size: 11;"/>
            <Label fx:id="cardOrders"  style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;" text="—"/>
        </VBox>
        <VBox style="-fx-background-color: #8e44ad; -fx-padding: 12; -fx-background-radius: 6;"
              prefWidth="160" alignment="CENTER">
            <Label text="Avg Order Value"  style="-fx-text-fill: white; -fx-font-size: 11;"/>
            <Label fx:id="cardAvgOrder"    style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;" text="—"/>
        </VBox>
        <VBox style="-fx-background-color: #16a085; -fx-padding: 12; -fx-background-radius: 6;"
              prefWidth="160" alignment="CENTER">
            <Label text="Active Customers" style="-fx-text-fill: white; -fx-font-size: 11;"/>
            <Label fx:id="cardCustomers"   style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;" text="—"/>
        </VBox>
        <VBox style="-fx-background-color: #e74c3c; -fx-padding: 12; -fx-background-radius: 6;"
              prefWidth="160" alignment="CENTER">
            <Label text="Low Stock Items" style="-fx-text-fill: white; -fx-font-size: 11;"/>
            <Label fx:id="cardLowStock"   style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;" text="—"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Refresh" onAction="#handleRefresh"
                style="-fx-background-color: #2c3e50; -fx-text-fill: white;"/>
    </HBox>

    <SplitPane dividerPositions="0.45" VBox.vgrow="ALWAYS">

        <!-- Left: Top products + order status -->
        <VBox spacing="8" style="-fx-padding: 0 6 0 0;">
            <Label text="Top 10 Products by Revenue" style="-fx-font-weight: bold;"/>
            <TableView fx:id="topProductsTable" VBox.vgrow="ALWAYS">
                <placeholder><Label text="No data"/></placeholder>
                <columns>
                    <TableColumn fx:id="colProdName"    text="Product"  prefWidth="200"/>
                    <TableColumn fx:id="colProdRevenue" text="Revenue"  prefWidth="100"/>
                    <TableColumn fx:id="colProdUnits"   text="Units"    prefWidth="70"/>
                </columns>
            </TableView>

            <Label text="Orders by Status" style="-fx-font-weight: bold;"/>
            <TableView fx:id="statusTable" prefHeight="160">
                <columns>
                    <TableColumn fx:id="colStatus"     text="Status"  prefWidth="110"/>
                    <TableColumn fx:id="colStatusCount" text="Count"  prefWidth="80"/>
                    <TableColumn fx:id="colStatusRev"  text="Revenue" prefWidth="100"/>
                </columns>
            </TableView>
        </VBox>

        <!-- Right: Full text report + monthly breakdown -->
        <VBox spacing="8" style="-fx-padding: 0 0 0 6;">
            <Label text="Full Report" style="-fx-font-weight: bold;"/>
            <TextArea fx:id="reportArea" VBox.vgrow="ALWAYS" editable="false"
                      style="-fx-font-family: 'Consolas', monospace; -fx-font-size: 11;"
                      wrapText="false"/>
        </VBox>

    </SplitPane>

</VBox>

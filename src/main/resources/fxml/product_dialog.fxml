<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<DialogPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.controller.ProductDialogController"
            prefWidth="440">

    <headerText>Product Details</headerText>

    <content>
        <VBox spacing="10" style="-fx-padding: 10 0 0 0;">

            <GridPane hgap="10" vgap="8">
                <columnConstraints>
                    <ColumnConstraints minWidth="110" halignment="RIGHT"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                </columnConstraints>

                <Label text="Name *"         GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="nameField" GridPane.rowIndex="0" GridPane.columnIndex="1"
                           promptText="Product name" maxWidth="Infinity"/>

                <Label text="Seller *"           GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <ComboBox fx:id="sellerCombo"    GridPane.rowIndex="1" GridPane.columnIndex="1"
                          maxWidth="Infinity" promptText="Select seller"/>

                <Label text="Category"             GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <ComboBox fx:id="categoryCombo"    GridPane.rowIndex="2" GridPane.columnIndex="1"
                          maxWidth="Infinity" promptText="Select category"/>

                <Label text="Price (RWF) *"    GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <TextField fx:id="priceField"  GridPane.rowIndex="3" GridPane.columnIndex="1"
                           promptText="e.g. 29.99"/>

                <Label text="Stock Quantity *"  GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                <TextField fx:id="stockField"   GridPane.rowIndex="4" GridPane.columnIndex="1"
                           promptText="e.g. 100"/>

                <Label text="Description"            GridPane.rowIndex="5" GridPane.columnIndex="0"
                       GridPane.valignment="TOP"/>
                <TextArea fx:id="descriptionArea"    GridPane.rowIndex="5" GridPane.columnIndex="1"
                          promptText="Optional product description"
                          prefRowCount="4" wrapText="true"/>
            </GridPane>

            <Label fx:id="errorLabel" text="" wrapText="true"
                   style="-fx-text-fill: #c0392b; -fx-font-size: 11;"/>

        </VBox>
    </content>

    <buttonTypes>
        <ButtonType fx:id="saveButtonType" text="Save"   buttonData="OK_DONE"/>
        <ButtonType                         text="Cancel" buttonData="CANCEL_CLOSE"/>
    </buttonTypes>

</DialogPane>

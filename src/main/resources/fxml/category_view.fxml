<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.controller.CategoryController"
      spacing="8" style="-fx-padding: 14;">

    <!-- ── Toolbar ── -->
    <HBox spacing="8" alignment="CENTER_LEFT">
        <Label text="Manage product categories" style="-fx-font-size: 13; -fx-font-weight: bold;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="addBtn"    text="Add Category"  onAction="#handleAdd"
                style="-fx-background-color: #27ae60; -fx-text-fill: white;"/>
        <Button fx:id="editBtn"   text="Edit"          onAction="#handleEdit"
                style="-fx-background-color: #f39c12; -fx-text-fill: white;"
                disable="true"/>
        <Button fx:id="deleteBtn" text="Delete"        onAction="#handleDelete"
                style="-fx-background-color: #e74c3c; -fx-text-fill: white;"
                disable="true"/>
    </HBox>

    <!-- ── Table ── -->
    <TableView fx:id="categoryTable" VBox.vgrow="ALWAYS">
        <placeholder>
            <Label text="No categories found"/>
        </placeholder>
        <columns>
            <TableColumn fx:id="colId"     text="ID"      prefWidth="55"/>
            <TableColumn fx:id="colName"   text="Name"    prefWidth="180"/>
            <TableColumn fx:id="colParent" text="Parent"  prefWidth="150"/>
            <TableColumn fx:id="colSlug"   text="Slug"    prefWidth="180"/>
            <TableColumn fx:id="colActive" text="Active"  prefWidth="65"/>
            <TableColumn fx:id="colCreated" text="Created" prefWidth="140"/>
        </columns>
    </TableView>

    <!-- ── Feedback ── -->
    <Label fx:id="feedbackLabel" text="" wrapText="true"
           style="-fx-text-fill: #27ae60; -fx-font-size: 12;"/>

</VBox>

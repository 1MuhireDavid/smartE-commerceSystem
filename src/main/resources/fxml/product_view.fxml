<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.controller.ProductController"
      spacing="8" style="-fx-padding: 14;">

    <fx:define>
        <ToggleGroup fx:id="sortGroup"/>
    </fx:define>

    <!-- ── Toolbar: search + filter ── -->
    <HBox spacing="8" alignment="CENTER_LEFT">
        <Label text="Search:"/>
        <TextField fx:id="searchField" promptText="Product name…"
                   prefWidth="220"
                   onAction="#handleSearch"/>
        <Label text="Category:"/>
        <ComboBox fx:id="categoryFilter" prefWidth="160"
                  onAction="#handleSearch"
                  promptText="All categories"/>
        <Button text="Search" onAction="#handleSearch"
                style="-fx-background-color: #2980b9; -fx-text-fill: white;"/>
        <Button text="Clear"  onAction="#handleClear"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="addBtn" text="Add Product" onAction="#handleAdd"
                style="-fx-background-color: #27ae60; -fx-text-fill: white;"/>
        <Button fx:id="editBtn" text="Edit" onAction="#handleEdit"
                style="-fx-background-color: #f39c12; -fx-text-fill: white;"
                disable="true"/>
        <Button fx:id="deleteBtn" text="Delete" onAction="#handleDelete"
                style="-fx-background-color: #e74c3c; -fx-text-fill: white;"
                disable="true"/>
        <Button fx:id="reviewsBtn" text="Reviews" onAction="#handleReviews"
                style="-fx-background-color: #8e44ad; -fx-text-fill: white;"
                disable="true"/>
    </HBox>

    <!-- ── Sort bar ── -->
    <HBox spacing="8" alignment="CENTER_LEFT">
        <Label text="Sort by:"/>
        <ToggleButton fx:id="sortNameAsc"  text="Name ↑"  toggleGroup="$sortGroup" onAction="#handleSort"/>
        <ToggleButton fx:id="sortNameDesc" text="Name ↓"  toggleGroup="$sortGroup" onAction="#handleSort"/>
        <ToggleButton fx:id="sortPriceAsc" text="Price ↑" toggleGroup="$sortGroup" onAction="#handleSort"/>
        <ToggleButton fx:id="sortPriceDesc" text="Price ↓" toggleGroup="$sortGroup" onAction="#handleSort"/>
        <ToggleButton fx:id="sortStockAsc" text="Stock ↑" toggleGroup="$sortGroup" onAction="#handleSort"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="resultCountLabel" text="" style="-fx-text-fill: #7f8c8d;"/>
    </HBox>

    <!-- ── Table ── -->
    <TableView fx:id="productTable" VBox.vgrow="ALWAYS">
        <placeholder>
            <Label text="No products found"/>
        </placeholder>

        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
            <TableColumn fx:id="colName" text="Name" prefWidth="240"/>
            <TableColumn fx:id="colCategory" text="Category" prefWidth="130"/>
            <TableColumn fx:id="colPrice" text="Price" prefWidth="90"/>
            <TableColumn fx:id="colStock" text="Stock" prefWidth="70"/>
            <TableColumn fx:id="colCreated" text="Added" prefWidth="130"/>
        </columns>
    </TableView>

    <!-- ── Pagination ── -->
    <HBox spacing="10" alignment="CENTER">
        <Button text="◀ Prev"  fx:id="prevBtn"  onAction="#handlePrev" disable="true"/>
        <Label  fx:id="pageLabel" text="Page 1"/>
        <Button text="Next ▶"  fx:id="nextBtn"  onAction="#handleNext" disable="true"/>
        <Label  text="Page size:"/>
        <ComboBox fx:id="pageSizeBox" prefWidth="70" onAction="#handlePageSize"/>
    </HBox>

    <!-- ── Feedback label ── -->
    <Label fx:id="feedbackLabel" text="" wrapText="true"
           style="-fx-text-fill: #27ae60; -fx-font-size: 12;"/>

</VBox>

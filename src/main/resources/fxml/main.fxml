<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.controller.MainController"
            prefWidth="1280" prefHeight="760"
            style="-fx-font-family: 'Segoe UI', Arial, sans-serif;">

    <!-- ── Top bar ── -->
    <top>
        <HBox style="-fx-background-color: #2c3e50; -fx-padding: 12 20;"
              alignment="CENTER_LEFT" spacing="10">
            <Label text="Smart E-Commerce System"
                   style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="statusLabel" text="Ready"
                   style="-fx-text-fill: #95a5a6; -fx-font-size: 12;"/>
        </HBox>
    </top>

    <!-- ── Main tab pane ── -->
    <center>
        <TabPane fx:id="mainTabPane" tabClosingPolicy="UNAVAILABLE">

            <Tab text="Products">
                <fx:include source="product_view.fxml"/>
            </Tab>

            <Tab text="Categories">
                <fx:include source="category_view.fxml"/>
            </Tab>

            <Tab text="Users">
                <fx:include source="users_view.fxml"/>
            </Tab>

            <Tab text="Orders">
                <fx:include source="orders_view.fxml"/>
            </Tab>

            <Tab text="Inventory">
                <fx:include source="inventory_view.fxml"/>
            </Tab>

            <Tab text="Reports">
                <fx:include source="reports_view.fxml"/>
            </Tab>

            <Tab text="Performance">
                <fx:include source="performance_view.fxml"/>
            </Tab>

            <Tab text="Carts">
                <fx:include source="cart_view.fxml"/>
            </Tab>

            <Tab fx:id="paymentTab" text="Payments">
                <fx:include fx:id="payment" source="payment_view.fxml"/>
            </Tab>

        </TabPane>
    </center>

</BorderPane>

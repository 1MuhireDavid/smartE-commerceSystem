<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.controller.OrderDetailController"
      spacing="10" style="-fx-padding: 14;" prefWidth="700" prefHeight="500">

    <Label fx:id="titleLabel" text="Order Details"
           style="-fx-font-size: 15; -fx-font-weight: bold;"/>

    <!-- ── Header info ── -->
    <GridPane hgap="14" vgap="6">
        <columnConstraints>
            <ColumnConstraints minWidth="110" halignment="RIGHT"/>
            <ColumnConstraints/>
            <ColumnConstraints minWidth="110" halignment="RIGHT"/>
            <ColumnConstraints/>
        </columnConstraints>

        <Label text="Customer:"       GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <Label fx:id="lblCustomer"    GridPane.rowIndex="0" GridPane.columnIndex="1"/>
        <Label text="Order #:"        GridPane.rowIndex="0" GridPane.columnIndex="2"/>
        <Label fx:id="lblOrderNumber" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

        <Label text="Status:"         GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <Label fx:id="lblStatus"      GridPane.rowIndex="1" GridPane.columnIndex="1"/>
        <Label text="Payment:"        GridPane.rowIndex="1" GridPane.columnIndex="2"/>
        <Label fx:id="lblPayment"     GridPane.rowIndex="1" GridPane.columnIndex="3"/>

        <Label text="Subtotal:"       GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <Label fx:id="lblSubtotal"    GridPane.rowIndex="2" GridPane.columnIndex="1"/>
        <Label text="Discount:"       GridPane.rowIndex="2" GridPane.columnIndex="2"/>
        <Label fx:id="lblDiscount"    GridPane.rowIndex="2" GridPane.columnIndex="3"/>

        <Label text="Total:"          GridPane.rowIndex="3" GridPane.columnIndex="0"
               style="-fx-font-weight: bold;"/>
        <Label fx:id="lblTotal"       GridPane.rowIndex="3" GridPane.columnIndex="1"
               style="-fx-font-weight: bold;"/>
        <Label text="Ordered At:"     GridPane.rowIndex="3" GridPane.columnIndex="2"/>
        <Label fx:id="lblOrderedAt"   GridPane.rowIndex="3" GridPane.columnIndex="3"/>
    </GridPane>

    <Separator/>

    <!-- ── Order items table ── -->
    <Label text="Order Items:" style="-fx-font-weight: bold;"/>
    <TableView fx:id="itemsTable" VBox.vgrow="ALWAYS">
        <placeholder><Label text="No items"/></placeholder>
        <columns>
            <TableColumn fx:id="colProduct"    text="Product"    prefWidth="260"/>
            <TableColumn fx:id="colQty"        text="Qty"        prefWidth="60"/>
            <TableColumn fx:id="colUnitPrice"  text="Unit Price" prefWidth="100"/>
            <TableColumn fx:id="colLineTotal"  text="Total"      prefWidth="100"/>
            <TableColumn fx:id="colItemStatus" text="Status"     prefWidth="100"/>
        </columns>
    </TableView>

</VBox>
